# This package builds a static site - devDependencies are ALWAYS required
# (docusaurus, webpack, patch-package, playwright). There is no meaningful
# "production install" here.
#
# NODE_ENV=production implicitly sets omit=dev, which drops those devDeps and
# then fails the postinstall hook - because patch-package, the thing postinstall
# runs, is itself a devDependency. The failure reads as a patch-package bug,
# which is why the workflows grew `|| npx patch-package || true` fallbacks.
#
# `include` beats `omit` in npm regardless of order, so this pins the behaviour
# no matter what NODE_ENV a caller happens to have set.
include=dev